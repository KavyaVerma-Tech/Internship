12. n = int(input("enter no: "))
    even = 0
    odd = 0
    for i in range(1,n+1):
        if i % 2 == 0:
            even = even + 1
        else:
            odd = odd + 1
    print("Even numbers between 1 and ",n , "is: ",even)
    print("Odd numbers between 1 and ",n , "is: ",odd)

